{
  "name": "HARP-Pose-Lite",
  "description": "Frozen-backbone, compute-efficient variant for PairUAV",
  "phase": 1,
  
  "model": {
    "type": "HARPPoseLite",
    "backbone": {
      "name": "resnet50",
      "pretrained": true,
      "frozen": true,
      "features_only": true,
      "out_indices": [4],
      "feature_dim": 2048
    },
    "head": {
      "input_channels": 4096,
      "hidden": 256,
      "output_grid": "7x7"
    },
    "aggregation": {
      "alpha": 10.0,
      "epsilon": 1e-6
    },
    "trainable_params_m": 1.2,
    "total_params_m": 26.2
  },
  
  "dataset": {
    "root": null,
    "train_buildings_fraction": 0.8,
    "val_buildings_fraction": 0.1,
    "test_buildings_fraction": 0.1,
    "max_train_pairs": 960000,
    "image_size": [224, 224],
    "normalization": {
      "mean": [0.4815, 0.4578, 0.4082],
      "std": [0.2686, 0.2613, 0.2758]
    },
    "augmentation": {
      "random_crop": [0.8, 1.0],
      "horizontal_flip": 0.5,
      "color_jitter": {
        "brightness": 0.2,
        "contrast": 0.2,
        "saturation": 0.2,
        "hue": 0.1
      },
      "random_rotation": 45,
      "target_no_aug": true
    }
  },
  
  "train": {
    "epochs": 30,
    "early_stopping_patience": 10,
    "optimizer": {
      "name": "AdamW",
      "lr": 0.0005,
      "betas": [0.9, 0.999],
      "weight_decay": 0.0001,
      "only_trainable": true
    },
    "scheduler": {
      "name": "CosineAnnealingLR",
      "warmup_epochs": 5,
      "eta_min": 1e-6
    },
    "batch_size": 384,
    "gradient_accumulation_steps": 1,
    "gradient_clip_norm": 1.0,
    "num_workers": 16,
    "pin_memory": true,
    "fp16": true,
    "seed": 42
  },
  
  "loss": {
    "lambda_pose": 1.0,
    "lambda_conf": 0.5,
    "lambda_cons": 0.2,
    "lambda_geo": 0.0
  },
  
  "output": {
    "checkpoint_dir": "checkpoints/",
    "checkpoint_name": "harp_pose_lite",
    "log_interval": 100,
    "val_interval": 1
  },
  
  "hardware": {
    "min_gpu_vram_gb": 8,
    "recommended_gpu": "RTX 5090 (32GB)",
    "estimated_time_hours": "1-3 (RTX 5090, cached-feature path)",
    "estimated_cost_usd": "0 (local) to 1 (cloud)"
  }
}
